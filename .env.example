APP_NAME="ChowdhuryBari SaaS"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://127.0.0.1:8000

# Central domain — used by stancl/tenancy to identify the central app
# vs tenant subdomains. For local dev with artisan serve, use 127.0.0.1.
# For vhost-based dev, use your hosts-file domain (e.g. chowdhurybari.test).
TENANCY_CENTRAL_DOMAINS=127.0.0.1

APP_LOCALE=bn
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=bn_BD

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ===== Central DB (the system DB — tenants, super_admins, products, orders, payments) =====
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=chowdhurybari_central
DB_USERNAME=root
DB_PASSWORD=

# ===== Tenant DB connection (used by stancl/tenancy to create + connect tenant databases) =====
# Each tenant gets its own DB. The connection below is the template —
# stancl switches the DB name per tenant at runtime.
TENANCY_DB_CONNECTION=mysql
TENANCY_DB_HOST=127.0.0.1
TENANCY_DB_PORT=3306
TENANCY_DB_USERNAME=root
TENANCY_DB_PASSWORD=
TENANCY_DB_PREFIX=tenant_   # tenant DBs will be named tenant_<uuid>

# IMPORTANT: SESSION_DOMAIN must match the host part of APP_URL.
# - For artisan serve on 127.0.0.1:8000 → SESSION_DOMAIN=null
# - For vhost chowdhurybari.test            → SESSION_DOMAIN=.chowdhurybari.test
# Setting it wrong causes 'login expired' / 419 CSRF errors on Filament forms.
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ===== Payment gateways (Phase 6 — leave blank for now) =====
# SSL Commerz (aggregator — handles bKash, Nagad, cards, banking)
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASSWD=
SSLCOMMERZ_MODE=sandbox   # sandbox | live

# bKash (direct integration — lower fees)
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_MODE=sandbox   # sandbox | live

# Nagad (direct integration)
NAGAD_MERCHANT_ID=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_MODE=sandbox   # sandbox | live

VITE_APP_NAME="${APP_NAME}"
